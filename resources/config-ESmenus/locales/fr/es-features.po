msgid "Controls localized original media selection. By default, APIExpose tries the ROM region first, then safe readable fallbacks."
msgstr "Controle la selection des medias originaux localises. Par defaut, APIExpose essaie la region de la ROM puis des fallbacks lisibles."

msgid "Controls whether logos and wheels favor user-readable language or the original ROM region."
msgstr "Controle si les logos et wheels privilegient une langue lisible par l utilisateur ou la region originale de la ROM."

msgid "global.apiexpose.media_allocation.logo_region_mode"
msgstr "global.apiexpose.media_allocation.logo_region_mode"

msgid "SCRAPE EXACT LOCAL MEDIA"
msgstr "SCRAPER LE MEDIA LOCAL EXACT"

msgid "Scrapes the exact prioritized regional media when a visible slot is only satisfied by a local fallback."
msgstr "Scrape le media regional prioritaire exact quand un slot visible est seulement satisfait par un fallback local."

msgid "global.apiexpose.scraping.exact_local_media.enabled"
msgstr "global.apiexpose.scraping.exact_local_media.enabled"

msgctxt "game_options"
msgid "REPAIR GAMELISTS ON STARTUP"
msgstr "REPARER LES GAMELISTS AU DEMARRAGE"

msgctxt "game_options"
msgid "Runs the startup pass that realigns visible gamelist media slots and localized text metadata. Manual reallocations still work when disabled."
msgstr "Realigne au demarrage les medias visibles et les textes localises des gamelists. Les reallocations manuelles restent disponibles si cette option est desactivee."

msgctxt "game_options"
msgid "global.apiexpose.api.repair_gamelists_on_startup"
msgstr "global.apiexpose.api.repair_gamelists_on_startup"
msgctxt "game_options"
msgid "SYNC GAMELISTS WITH SYSTEM LANGUAGE"
msgstr "SYNCHRONISER LES GAMELISTS AVEC LA LANGUE SYSTEME"

msgctxt "game_options"
msgid "When the EmulationStation system language changes, APIExpose updates gamelists with localized metadata for the new language."
msgstr "Quand la langue systeme EmulationStation change, APIExpose met a jour les gamelists avec les metadonnees localisees dans la nouvelle langue."

msgctxt "game_options"
msgid "global.apiexpose.api.sync_gamelists_with_system_language"
msgstr "global.apiexpose.api.sync_gamelists_with_system_language"


